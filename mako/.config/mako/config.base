font=JetBrainsMono Nerd Font 10

anchor=top-right
layer=overlay
width=360
height=140
outer-margin=14
margin=8
padding=12,14
border-size=2
border-radius=0

icons=1
max-icon-size=48
icon-border-radius=0
markup=1
text-alignment=left

sort=-time
max-visible=4
history=1
max-history=10
default-timeout=5000
ignore-timeout=1

on-button-left=dismiss
on-button-middle=dismiss-all
on-button-right=dismiss
on-touch=dismiss
