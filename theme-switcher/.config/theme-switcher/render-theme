#!/usr/bin/env bash
set -euo pipefail

mode="${1:-tokyonight-night}"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/theme-switcher"
theme_dir="$config_dir/theme-switcher"

mkdir -p "$state_dir" "$config_dir/hypr/themes" "$config_dir/waybar/themes" "$config_dir/rofi/themes"
mkdir -p "$config_dir/ghostty" "$config_dir/mako" "$config_dir/gtk-3.0" "$config_dir/gtk-4.0"

load_palette() {
  case "$mode" in
    tokyonight-night)
      source "$theme_dir/tokyonight-night.env"
      ;;
    matugen)
      if [ -f /tmp/qs_colors.json ] && command -v python3 >/dev/null 2>&1; then
        eval "$(python3 - <<'PY'
import json, shlex
with open("/tmp/qs_colors.json", "r", encoding="utf-8") as f:
    d = json.load(f)
mapping = {
    "THEME_NAME": "Matugen",
    "THEME_MODE": "matugen",
    "BASE": d.get("base", "#111318"),
    "BASE_ALT": d.get("surface0", "#1b1b20"),
    "SURFACE": d.get("surface1", "#22242a"),
    "SURFACE_HOVER": d.get("surface2", "#3f4754"),
    "TEXT": d.get("text", "#e2e2e9"),
    "TEXT_MUTED": d.get("subtext1", "#c3c6d0"),
    "BORDER": d.get("overlay1", "#8d9199"),
    "PRIMARY": d.get("blue", "#adc6ff"),
    "SECONDARY": d.get("mauve", "#c4c6d0"),
    "CYAN": d.get("sapphire", "#b7c9d9"),
    "GREEN": d.get("green", "#b8cea8"),
    "YELLOW": d.get("yellow", "#dbc48e"),
    "RED": d.get("red", "#ffb4ab"),
}
for k, v in mapping.items():
    print(f"{k}={shlex.quote(str(v))}")
PY
)"
        HYPR_ACTIVE="${PRIMARY#'#'}ee"
        HYPR_INACTIVE="${BORDER#'#'}aa"
      else
        source "$theme_dir/matugen-fallback.env"
      fi
      ;;
    *)
      echo "Unknown theme mode: $mode" >&2
      exit 2
      ;;
  esac
}

load_palette
display_name="${THEME_DISPLAY_NAME:-$THEME_NAME}"

RADIUS_NONE="0px"
RADIUS_SMALL="0px"
RADIUS_MEDIUM="0px"
RADIUS_LARGE="0px"
BORDER_WIDTH="2px"
FONT_UI="JetBrainsMono Nerd Font"
FONT_ICON="Iosevka Nerd Font"
ROFI_FONT="JetBrainsMono Nerd Font 12"
ROFI_WIDTH="30%"
ROFI_Y_OFFSET="18px"
ROFI_PADDING="10px"
ROFI_ITEM_PADDING="5px 8px"
ROFI_INPUT_PADDING="7px 10px"
ROFI_SPACING="6px"

cat > "$theme_dir/current.env" <<EOF
THEME_NAME="$THEME_NAME"
THEME_MODE="$THEME_MODE"
BASE="$BASE"
BASE_ALT="$BASE_ALT"
SURFACE="$SURFACE"
SURFACE_HOVER="$SURFACE_HOVER"
TEXT="$TEXT"
TEXT_MUTED="$TEXT_MUTED"
BORDER="$BORDER"
PRIMARY="$PRIMARY"
SECONDARY="$SECONDARY"
CYAN="$CYAN"
GREEN="$GREEN"
YELLOW="$YELLOW"
RED="$RED"
HYPR_ACTIVE="$HYPR_ACTIVE"
HYPR_INACTIVE="$HYPR_INACTIVE"
RADIUS_NONE="$RADIUS_NONE"
RADIUS_SMALL="$RADIUS_SMALL"
RADIUS_MEDIUM="$RADIUS_MEDIUM"
RADIUS_LARGE="$RADIUS_LARGE"
BORDER_WIDTH="$BORDER_WIDTH"
FONT_UI="$FONT_UI"
FONT_ICON="$FONT_ICON"
ROFI_FONT="$ROFI_FONT"
EOF

cat > "$theme_dir/current.json" <<EOF
{
  "name": "$THEME_NAME",
  "mode": "$THEME_MODE",
  "base": "$BASE",
  "base_alt": "$BASE_ALT",
  "surface": "$SURFACE",
  "surface_hover": "$SURFACE_HOVER",
  "text": "$TEXT",
  "text_muted": "$TEXT_MUTED",
  "border": "$BORDER",
  "primary": "$PRIMARY",
  "secondary": "$SECONDARY",
  "cyan": "$CYAN",
  "green": "$GREEN",
  "yellow": "$YELLOW",
  "red": "$RED",
  "radius_none": "$RADIUS_NONE",
  "radius_small": "$RADIUS_SMALL",
  "radius_medium": "$RADIUS_MEDIUM",
  "radius_large": "$RADIUS_LARGE",
  "border_width": "$BORDER_WIDTH",
  "font_ui": "$FONT_UI",
  "font_icon": "$FONT_ICON",
  "rofi_font": "$ROFI_FONT"
}
EOF

cat > "$theme_dir/current.css" <<EOF
/* Canonical theme tokens generated by theme-switcher. */
:root {
  --theme-bg: $BASE;
  --theme-bg-alt: $BASE_ALT;
  --theme-surface: $SURFACE;
  --theme-surface-hover: $SURFACE_HOVER;
  --theme-fg: $TEXT;
  --theme-fg-muted: $TEXT_MUTED;
  --theme-border: $BORDER;
  --theme-primary: $PRIMARY;
  --theme-secondary: $SECONDARY;
  --theme-cyan: $CYAN;
  --theme-green: $GREEN;
  --theme-yellow: $YELLOW;
  --theme-red: $RED;
  --theme-radius-none: $RADIUS_NONE;
  --theme-radius-small: $RADIUS_SMALL;
  --theme-radius-medium: $RADIUS_MEDIUM;
  --theme-radius-large: $RADIUS_LARGE;
  --theme-border-width: $BORDER_WIDTH;
  --theme-font-ui: "$FONT_UI";
  --theme-font-icon: "$FONT_ICON";
}
EOF

cat > "$config_dir/hypr/themes/current.conf" <<EOF
# Generated by theme-switcher. Edit the palettes, not this file.
general {
    col.active_border = rgba($HYPR_ACTIVE)
    col.inactive_border = rgba($HYPR_INACTIVE)
}
EOF

cat > "$config_dir/waybar/themes/current.css" <<EOF
/* Waybar adapter generated from ~/.config/theme-switcher/current.* */
@define-color bg $BASE;
@define-color bg_alt $BASE_ALT;
@define-color surface $SURFACE;
@define-color surface_hover $SURFACE_HOVER;
@define-color fg $TEXT;
@define-color fg_muted $TEXT_MUTED;
@define-color border $BORDER;
@define-color primary $PRIMARY;
@define-color secondary $SECONDARY;
@define-color cyan $CYAN;
@define-color green $GREEN;
@define-color yellow $YELLOW;
@define-color red $RED;
EOF

cat > "$config_dir/rofi/themes/current.rasi" <<EOF
/* Rofi adapter generated from ~/.config/theme-switcher/current.* */
* {
    bg:             $BASE;
    bg-alt:         $BASE_ALT;
    fg:             $TEXT;
    fg-muted:       $TEXT_MUTED;
    blue:           $PRIMARY;
    cyan:           $CYAN;
    purple:         $SECONDARY;
    border:         $BORDER;
    urgent:         $RED;
    radius-none:    $RADIUS_NONE;
    radius-small:   $RADIUS_SMALL;
    radius-medium:  $RADIUS_MEDIUM;
    radius-large:   $RADIUS_LARGE;
    border-width:   $BORDER_WIDTH;
    rofi-font:      "$ROFI_FONT";
    rofi-width:     $ROFI_WIDTH;
    rofi-y-offset:  $ROFI_Y_OFFSET;
    rofi-padding:   $ROFI_PADDING;
    item-padding:   $ROFI_ITEM_PADDING;
    input-padding:  $ROFI_INPUT_PADDING;
    rofi-spacing:   $ROFI_SPACING;
}
EOF

cat > "$config_dir/ghostty/theme-current" <<EOF
# Ghostty adapter generated from ~/.config/theme-switcher/current.*
theme =
background = $BASE
foreground = $TEXT
cursor-color = $PRIMARY
selection-background = $SURFACE_HOVER
selection-foreground = $TEXT
palette = 0=$BASE
palette = 1=$RED
palette = 2=$GREEN
palette = 3=$YELLOW
palette = 4=$PRIMARY
palette = 5=$SECONDARY
palette = 6=$CYAN
palette = 7=$TEXT
palette = 8=$TEXT_MUTED
palette = 9=$RED
palette = 10=$GREEN
palette = 11=$YELLOW
palette = 12=$PRIMARY
palette = 13=$SECONDARY
palette = 14=$CYAN
palette = 15=$TEXT
EOF

cat "$config_dir/mako/config.base" > "$config_dir/mako/config"
cat >> "$config_dir/mako/config" <<EOF

# Theme section generated from ~/.config/theme-switcher/current.*
background-color=${BASE}F2
text-color=${TEXT}FF
border-color=${PRIMARY}FF
progress-color=over ${PRIMARY}FF
format=<b>%s</b>\n<span foreground="${TEXT_MUTED}">%b</span>

[urgency=low]
border-color=${TEXT_MUTED}FF
progress-color=over ${TEXT_MUTED}FF

[urgency=normal]
border-color=${PRIMARY}FF
progress-color=over ${PRIMARY}FF

[urgency=critical]
background-color=${SURFACE}FA
text-color=${RED}FF
border-color=${RED}FF
progress-color=over ${RED}FF
default-timeout=0
EOF

cat > "$config_dir/gtk-3.0/theme-switcher.css" <<EOF
@define-color theme_bg_color $BASE;
@define-color theme_fg_color $TEXT;
@define-color window_bg_color $BASE;
@define-color window_fg_color $TEXT;
@define-color view_bg_color $BASE_ALT;
@define-color view_fg_color $TEXT;
@define-color headerbar_bg_color $SURFACE;
@define-color headerbar_fg_color $TEXT;
@define-color popover_bg_color $SURFACE;
@define-color popover_fg_color $TEXT;
@define-color card_bg_color $SURFACE;
@define-color card_fg_color $TEXT;
@define-color accent_color $PRIMARY;
@define-color accent_bg_color $PRIMARY;
@define-color accent_fg_color $BASE;
EOF

cp "$config_dir/gtk-3.0/theme-switcher.css" "$config_dir/gtk-4.0/theme-switcher.css"

cat > "$config_dir/gtk-3.0/gtk.css" <<EOF
@import url("theme-switcher.css");
EOF

cat > "$config_dir/gtk-4.0/gtk.css" <<EOF
@import url("theme-switcher.css");
EOF

printf '%s\n' "$mode" > "$state_dir/current-mode"
printf '%s\n' "$display_name" > "$state_dir/current-name"
