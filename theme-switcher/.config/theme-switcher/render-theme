const HOST_NAME = "theme_activity_firefox";

let port = null;

function connect() {
  try {
    port = browser.runtime.connectNative(HOST_NAME);
    port.onDisconnect.addListener(() => {
      port = null;
      setTimeout(connect, 1000);
    });
  } catch (error) {
    port = null;
    setTimeout(connect, 1000);
  }
}

async function reportActiveTab() {
  if (!port) {
    return;
  }

  try {
    const [tab] = await browser.tabs.query({ active: true, lastFocusedWindow: true });
    if (!tab) {
      return;
    }

    port.postMessage({
      url: tab.url || "",
      title: tab.title || "",
      tabId: tab.id,
      windowId: tab.windowId,
    });
  } catch (error) {
    // Firefox can briefly reject tab queries during startup or shutdown.
  }
}

connect();
browser.tabs.onActivated.addListener(reportActiveTab);
browser.tabs.onUpdated.addListener((tabId, changeInfo, tab) => {
  if (tab.active && (changeInfo.url || changeInfo.title || changeInfo.status === "complete")) {
    reportActiveTab();
  }
});
browser.windows.onFocusChanged.addListener(reportActiveTab);
browser.runtime.onStartup.addListener(reportActiveTab);
setInterval(reportActiveTab, 5000);
reportActiveTab();
EOF
