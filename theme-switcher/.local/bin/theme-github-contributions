#!/usr/bin/env python3
import html
import json
import os
import re
import sys
import time
import urllib.request
from pathlib import Path


USER = os.environ.get("THEME_GITHUB_USER", "ferdipret")
URL = f"https://github.com/{USER}?action=show&controller=profiles&tab=contributions&user_id={USER}"


def config_dir() -> Path:
    return Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "theme-switcher"


def fetch() -> str:
    request = urllib.request.Request(
        URL,
        headers={
            "Accept": "text/html",
            "User-Agent": "Mozilla/5.0",
            "X-Requested-With": "XMLHttpRequest",
        },
    )
    with urllib.request.urlopen(request, timeout=20) as response:
        return response.read().decode("utf-8", "replace")


def parse(fragment: str) -> dict:
    total_match = re.search(
        r'<h2[^>]*id="js-contribution-activity-description"[^>]*>\s*([0-9,]+)\s+contributions?',
        fragment,
        re.S,
    )
    total = int(total_match.group(1).replace(",", "")) if total_match else 0

    range_match = re.search(
        r'data-from="([^"]+)".*?data-to="([^"]+)"',
        fragment,
        re.S,
    )

    days = []
    day_pattern = re.compile(
        r'<td[^>]*data-date="([^"]+)"[^>]*data-level="([0-4])"[^>]*></td>\s*'
        r'<tool-tip[^>]*>(.*?)</tool-tip>',
        re.S,
    )

    for date, level, tooltip in day_pattern.findall(fragment):
        label = html.unescape(re.sub(r"\s+", " ", tooltip)).strip()
        count_match = re.match(r"([0-9,]+) contributions?", label)
        count = int(count_match.group(1).replace(",", "")) if count_match else 0
        days.append({
            "date": date,
            "level": int(level),
            "count": count,
            "label": label,
        })

    if not days:
        raise RuntimeError("could not find contribution days in GitHub response")

    return {
        "user": USER,
        "total": total,
        "from": range_match.group(1).split()[0] if range_match else days[0]["date"],
        "to": range_match.group(2).split()[0] if range_match else days[-1]["date"],
        "updated_at": int(time.time()),
        "days": days,
    }


def main() -> int:
    out_dir = config_dir()
    out_dir.mkdir(parents=True, exist_ok=True)
    out_file = out_dir / "github-contributions.json"
    script_file = out_dir / "github-contributions.js"

    payload = parse(fetch())
    tmp = out_file.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(payload, separators=(",", ":")), encoding="utf-8")
    tmp.replace(out_file)
    script_tmp = script_file.with_suffix(".js.tmp")
    script_tmp.write_text(
        "window.__themeGithubContributions="
        + json.dumps(payload, separators=(",", ":"))
        + ";\n",
        encoding="utf-8",
    )
    script_tmp.replace(script_file)
    print(f"Wrote {len(payload['days'])} contribution days to {out_file}")
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        print(f"theme-github-contributions: {exc}", file=sys.stderr)
        raise SystemExit(1)
