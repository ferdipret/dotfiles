#!/usr/bin/env python3
import os
import sqlite3
from datetime import date
from pathlib import Path


def state_dir() -> Path:
    base = os.environ.get("XDG_STATE_HOME")
    if base:
        return Path(base) / "theme-switcher"
    return Path.home() / ".local/state/theme-switcher"


def fmt(seconds: int) -> str:
    if seconds < 60:
        return f"{seconds}s"
    minutes = round(seconds / 60)
    hours, mins = divmod(minutes, 60)
    if hours:
        return f"{hours}h {mins:02d}m"
    return f"{mins}m"


db = state_dir() / "activity.sqlite3"
if not db.exists():
    print("No activity data yet.")
    raise SystemExit(0)

conn = sqlite3.connect(db)
today = date.today().isoformat()

for kind, title in (("app", "Apps"), ("domain", "Firefox domains")):
    print(title)
    rows = conn.execute(
        """
        SELECT label, seconds
        FROM usage
        WHERE day = ? AND kind = ?
        ORDER BY seconds DESC
        LIMIT 12
        """,
        (today, kind),
    ).fetchall()
    if not rows:
        print("  none")
    for label, seconds in rows:
        print(f"  {fmt(seconds):>7}  {label}")
    print()
