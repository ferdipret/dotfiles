#!/usr/bin/env bash
set -euo pipefail

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/theme-switcher"
renderer="$config_dir/theme-switcher/render-theme"
wallpaper_dir="${THEME_SWITCHER_WALLPAPER_DIR:-$HOME/Pictures/Wallpapers}"
wallpaper_apply="$HOME/.local/bin/apply-wallpaper-theme"
quickshell_picker="$config_dir/theme-switcher/quickshell/WallpaperPicker.qml"
picker_theme='
window {
  width: 82%;
  location: center;
  anchor: center;
  border: @border-width;
  border-color: @border;
  border-radius: @radius-none;
  background-color: @bg;
}

mainbox {
  spacing: 10px;
  padding: 12px;
}

inputbar {
  padding: 8px 10px;
  background-color: @bg-alt;
  border-radius: @radius-none;
}

message {
  padding: 0 2px;
  background-color: transparent;
  text-color: @fg-muted;
}

listview {
  lines: 1;
  columns: 5;
  fixed-height: true;
  spacing: 8px;
  scrollbar: false;
}

element {
  orientation: vertical;
  children: [ element-icon, element-text ];
  spacing: 8px;
  padding: 8px;
  border-radius: @radius-none;
}

element selected {
  background-color: @blue;
  text-color: @bg;
}

element-icon {
  size: 12em;
  border-radius: @radius-none;
}

element-text {
  horizontal-align: 0.5;
  vertical-align: 0.5;
}
'

theme_menu() {
  current="$(cat "$state_dir/current-name" 2>/dev/null || true)"

  {
    printf '%s\0display\x1f%s\0icon\x1f%s\n' "tokyonight-night" "Tokyo Night" "preferences-desktop-theme"
    if [ -d "$wallpaper_dir" ]; then
      find "$wallpaper_dir" -maxdepth 1 -type f \
        \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' -o -iname '*.bmp' \) \
        -print0 \
        | sort -z \
        | while IFS= read -r -d '' wallpaper; do
            name="${wallpaper##*/}"
            name="${name%.*}"
            printf '%s\0display\x1f%s\0icon\x1fthumbnail://%s\n' "$wallpaper" "$name" "$wallpaper"
          done
    fi
  } | rofi \
        -dmenu \
        -i \
        -show-icons \
        -p "Theme" \
        -mesg "Current: ${current:-unknown}" \
        -theme-str "$picker_theme"
}

choice="${1:-}"

if [ -z "$choice" ]; then
  qs_bin="$(command -v quickshell || command -v qs || true)"
  if [ -n "$qs_bin" ] && [ -f "$quickshell_picker" ]; then
    exec "$qs_bin" -p "$quickshell_picker"
  fi

  choice="$(theme_menu)"
fi

case "$choice" in
  matugen|"Matugen wallpaper colors")
    mode="matugen"
    ;;
  tokyonight-night|"Tokyo Night")
    mode="tokyonight-night"
    ;;
  "$wallpaper_dir"/*)
    exec "$wallpaper_apply" "$choice"
    ;;
  "")
    exit 0
    ;;
  *)
    notify-send "Theme switcher" "Unknown theme: $choice" 2>/dev/null || true
    exit 2
    ;;
esac

bash "$renderer" "$mode"

hyprctl reload >/dev/null 2>&1 || true

pkill -x waybar >/dev/null 2>&1 || true
sleep 0.2
hyprctl dispatch exec waybar >/dev/null 2>&1 || {
  if [ -n "${WAYLAND_DISPLAY:-}" ]; then
    waybar >/dev/null 2>&1 &
  fi
}

makoctl reload >/dev/null 2>&1 || true

if command -v gsettings >/dev/null 2>&1; then
  gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' >/dev/null 2>&1 || true
fi

notify-send "Theme switcher" "Applied $(cat "$state_dir/current-name")" 2>/dev/null || true
