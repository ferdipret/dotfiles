#!/usr/bin/env python3
import json
import os
import sqlite3
import subprocess
import time
from datetime import datetime
from pathlib import Path
from urllib.parse import urlparse


INTERVAL_SECONDS = 1.0


def state_dir() -> Path:
    base = os.environ.get("XDG_STATE_HOME")
    if base:
        return Path(base) / "theme-switcher"
    return Path.home() / ".local/state/theme-switcher"


STATE_DIR = state_dir()
DB_PATH = STATE_DIR / "activity.sqlite3"
FIREFOX_TAB_PATH = STATE_DIR / "firefox-active-tab.json"


def connect_db() -> sqlite3.Connection:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("""
        CREATE TABLE IF NOT EXISTS usage (
            day TEXT NOT NULL,
            kind TEXT NOT NULL,
            key TEXT NOT NULL,
            label TEXT NOT NULL,
            seconds INTEGER NOT NULL DEFAULT 0,
            updated_at REAL NOT NULL,
            PRIMARY KEY (day, kind, key)
        )
    """)
    conn.execute("""
        CREATE TABLE IF NOT EXISTS events (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            started_at REAL NOT NULL,
            ended_at REAL NOT NULL,
            app_key TEXT NOT NULL,
            app_label TEXT NOT NULL,
            domain TEXT,
            url TEXT,
            title TEXT
        )
    """)
    return conn


def active_window() -> dict:
    try:
        raw = subprocess.check_output(["hyprctl", "-j", "activewindow"], text=True, timeout=1.5)
        data = json.loads(raw)
        if not data or data.get("mapped") is False:
            return {}
        return data
    except Exception:
        return {}


def firefox_tab() -> dict:
    try:
        return json.loads(FIREFOX_TAB_PATH.read_text(encoding="utf-8"))
    except Exception:
        return {}


def clean_domain(url: str) -> str:
    try:
        host = (urlparse(url).hostname or "").lower()
    except Exception:
        return ""
    if host.startswith("www."):
        host = host[4:]
    for domain in ("youtube.com", "youtu.be", "chatgpt.com", "chat.openai.com", "github.com"):
        if host == domain or host.endswith(f".{domain}"):
            return domain
    return host


def pretty_domain(domain: str) -> str:
    names = {
        "youtube.com": "YouTube",
        "youtu.be": "YouTube",
        "chatgpt.com": "ChatGPT",
        "chat.openai.com": "ChatGPT",
        "github.com": "GitHub",
    }
    return names.get(domain, domain)


def pretty_app(app_key: str) -> str:
    names = {
        "firefox-developer-edition": "Firefox",
        "com.mitchellh.ghostty": "Ghostty",
        "codex": "Codex",
    }
    return names.get(app_key.lower(), app_key or "Unknown")


def is_firefox(app_key: str) -> bool:
    app = app_key.lower()
    return "firefox" in app or "librewolf" in app or "floorp" in app or "zen" in app


def usage_key(window: dict) -> dict:
    app_key = str(window.get("class") or window.get("initialClass") or "unknown")
    app_label = pretty_app(app_key)
    title = str(window.get("title") or "")
    url = ""
    domain = ""

    if is_firefox(app_key):
        tab = firefox_tab()
        url = str(tab.get("url") or "")
        domain = clean_domain(url) or str(tab.get("domain") or "").lower()
        title = str(tab.get("title") or title)

    return {
        "app_key": app_key.lower(),
        "app_label": app_label,
        "domain": domain.lower(),
        "url": url,
        "title": title,
    }


def add_usage(conn: sqlite3.Connection, day: str, kind: str, key: str, label: str, seconds: int, now: float) -> None:
    if not key:
        return
    conn.execute(
        """
        INSERT INTO usage(day, kind, key, label, seconds, updated_at)
        VALUES (?, ?, ?, ?, ?, ?)
        ON CONFLICT(day, kind, key) DO UPDATE SET
            seconds = seconds + excluded.seconds,
            label = excluded.label,
            updated_at = excluded.updated_at
        """,
        (day, kind, key, label, seconds, now),
    )


def flush_event(conn: sqlite3.Connection, current: dict, started_at: float, ended_at: float) -> None:
    if not current or ended_at <= started_at:
        return
    conn.execute(
        """
        INSERT INTO events(started_at, ended_at, app_key, app_label, domain, url, title)
        VALUES (?, ?, ?, ?, ?, ?, ?)
        """,
        (
            started_at,
            ended_at,
            current["app_key"],
            current["app_label"],
            current.get("domain") or None,
            current.get("url") or None,
            current.get("title") or None,
        ),
    )


def main() -> int:
    conn = connect_db()
    current = {}
    event_started_at = time.time()

    while True:
        loop_started = time.time()
        window = active_window()
        snapshot = usage_key(window) if window else {}
        now = time.time()
        day = datetime.fromtimestamp(now).date().isoformat()

        if snapshot != current:
            flush_event(conn, current, event_started_at, now)
            current = snapshot
            event_started_at = now

        if snapshot:
            add_usage(conn, day, "app", snapshot["app_key"], snapshot["app_label"], 1, now)
            if snapshot.get("domain"):
                add_usage(conn, day, "domain", snapshot["domain"], pretty_domain(snapshot["domain"]), 1, now)
            conn.commit()

        elapsed = time.time() - loop_started
        time.sleep(max(0.1, INTERVAL_SECONDS - elapsed))


if __name__ == "__main__":
    raise SystemExit(main())
