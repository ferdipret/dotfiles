#!/usr/bin/env bash
set -euo pipefail

wallpaper="${1:-}"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/theme-switcher"
matugen_output="/tmp/qs_colors.json"
matugen_config="$config_dir/matugen/config.toml"

if [ -z "$wallpaper" ]; then
  notify-send "Wallpaper theme" "Pass a wallpaper path" 2>/dev/null || true
  exit 2
fi

if [ ! -f "$wallpaper" ]; then
  notify-send "Wallpaper theme" "Not found: $wallpaper" 2>/dev/null || true
  exit 2
fi

if command -v hyprctl >/dev/null 2>&1 && pgrep -x hyprpaper >/dev/null 2>&1; then
  hyprctl hyprpaper preload "$wallpaper" >/dev/null 2>&1 || true
  hyprctl monitors -j 2>/dev/null \
    | python3 -c 'import json,sys; print("\n".join(m.get("name","") for m in json.load(sys.stdin)))' 2>/dev/null \
    | while IFS= read -r monitor; do
        [ -n "$monitor" ] || continue
        hyprctl hyprpaper wallpaper "$monitor,$wallpaper" >/dev/null 2>&1 || true
      done
fi

if ! command -v matugen >/dev/null 2>&1; then
  notify-send "Wallpaper theme" "Wallpaper applied, but matugen is not installed" 2>/dev/null || true
  /home/ferdi/.local/bin/theme-switcher matugen
  exit 0
fi

mkdir -p "$state_dir"
rm -f "$matugen_output"

matugen_args=(image --mode dark --type scheme-vibrant --source-color-index 0)
if [ -f "$matugen_config" ]; then
  matugen_args=(--config "$matugen_config" "${matugen_args[@]}")
fi

matugen "${matugen_args[@]}" "$wallpaper"

if [ ! -s "$matugen_output" ]; then
  notify-send "Wallpaper theme" "Wallpaper applied, but Matugen did not generate colors" 2>/dev/null || true
  exit 1
fi

printf '%s\n' "$wallpaper" > "$state_dir/current-wallpaper"
THEME_DISPLAY_NAME="Wallpaper: ${wallpaper##*/}" /home/ferdi/.local/bin/theme-switcher matugen
