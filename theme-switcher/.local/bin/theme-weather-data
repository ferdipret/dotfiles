#!/usr/bin/env python3
import json
import os
import time
import urllib.parse
import urllib.request
from datetime import datetime

CACHE_DIR = os.path.join(os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache")), "theme-switcher")
CACHE_FILE = os.path.join(CACHE_DIR, "weather-widget.json")
CACHE_TTL = 15 * 60


def fetch_json(url):
    req = urllib.request.Request(url, headers={"User-Agent": "theme-shell-weather"})
    with urllib.request.urlopen(req, timeout=7) as response:
        return json.load(response)


def weather_icon(code, is_day=True):
    code = int(code)
    if code == 0:
        return ("☀" if is_day else "☾", "Clear")
    if code in (1, 2):
        return ("🌤", "Partly cloudy")
    if code == 3:
        return ("☁", "Cloudy")
    if code in (45, 48):
        return ("🌫", "Fog")
    if code in (51, 53, 55, 56, 57):
        return ("🌧", "Drizzle")
    if code in (61, 63, 65, 66, 67, 80, 81, 82):
        return ("🌧", "Rain")
    if code in (71, 73, 75, 77, 85, 86):
        return ("❄", "Snow")
    if code in (95, 96, 99):
        return ("⚡", "Storm")
    return ("☁", "Cloudy")


def fmt_temp(value):
    return f"{round(float(value))}°"


def get_location():
    wttr = fetch_json("https://wttr.in/?format=j1")
    area = wttr.get("nearest_area", [{}])[0]
    name = area.get("areaName", [{}])[0].get("value", "Current location")
    country = area.get("country", [{}])[0].get("value", "")
    lat = area.get("latitude")
    lon = area.get("longitude")
    return name, country, lat, lon


def get_payload():
    os.makedirs(CACHE_DIR, exist_ok=True)
    if os.path.exists(CACHE_FILE) and time.time() - os.path.getmtime(CACHE_FILE) < CACHE_TTL:
        with open(CACHE_FILE, "r", encoding="utf-8") as handle:
            return json.load(handle)

    name, country, lat, lon = get_location()
    if not lat or not lon:
        raise RuntimeError("Could not detect location")

    params = {
        "latitude": lat,
        "longitude": lon,
        "timezone": "auto",
        "current": "temperature_2m,relative_humidity_2m,precipitation,weather_code,is_day,wind_speed_10m",
        "hourly": "temperature_2m,precipitation_probability,weather_code",
        "daily": "weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max",
    }
    url = "https://api.open-meteo.com/v1/forecast?" + urllib.parse.urlencode(params)
    data = fetch_json(url)
    payload = {"location": {"name": name, "country": country}, "forecast": data}
    with open(CACHE_FILE, "w", encoding="utf-8") as handle:
        json.dump(payload, handle)
    return payload


def build_response(payload):
    data = payload["forecast"]
    current = data["current"]
    is_day = bool(current.get("is_day", 1))
    icon, desc = weather_icon(current["weather_code"], is_day)
    now = datetime.now()
    today = now.date().isoformat()

    daily = []
    for day, code, hi, lo, rain in zip(
        data["daily"]["time"],
        data["daily"]["weather_code"],
        data["daily"]["temperature_2m_max"],
        data["daily"]["temperature_2m_min"],
        data["daily"]["precipitation_probability_max"],
    ):
        dt = datetime.fromisoformat(day)
        day_icon, day_desc = weather_icon(code)
        daily.append(
            {
                "day": dt.strftime("%a"),
                "date": dt.strftime("%A, %-d %B") if os.name != "nt" else dt.strftime("%A, %#d %B"),
                "icon": day_icon,
                "description": day_desc,
                "high": fmt_temp(hi),
                "low": fmt_temp(lo),
                "precipitation": int(rain),
                "tempMax": round(float(hi)),
                "tempMin": round(float(lo)),
            }
        )

    hourly = []
    for hour, temp, rain, code in zip(
        data["hourly"]["time"],
        data["hourly"]["temperature_2m"],
        data["hourly"]["precipitation_probability"],
        data["hourly"]["weather_code"],
    ):
        dt = datetime.fromisoformat(hour)
        if dt.date().isoformat() != today:
            continue
        hour_icon, hour_desc = weather_icon(code, 6 <= dt.hour < 20)
        hourly.append(
            {
                "time": dt.strftime("%H:%M"),
                "hour": dt.hour,
                "icon": hour_icon,
                "description": hour_desc,
                "temp": fmt_temp(temp),
                "tempValue": round(float(temp)),
                "precipitation": int(rain),
            }
        )

    return {
        "location": payload["location"],
        "current": {
            "time": now.strftime("%A %H:%M"),
            "icon": icon,
            "description": desc,
            "temp": fmt_temp(current["temperature_2m"]),
            "tempValue": round(float(current["temperature_2m"])),
            "humidity": int(current.get("relative_humidity_2m", 0)),
            "precipitation": float(current.get("precipitation", 0)),
            "wind": round(float(current.get("wind_speed_10m", 0))),
        },
        "daily": daily,
        "hourly": hourly,
    }


def main():
    try:
        print(json.dumps(build_response(get_payload()), ensure_ascii=False))
    except Exception as exc:
        print(json.dumps({"error": str(exc), "current": {"temp": "--", "icon": "☁", "description": "Unavailable"}}))


if __name__ == "__main__":
    main()
